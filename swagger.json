          }
        ],
        "responses": {
          "200": {
            "description": "Leave success flag",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JoinLeaveResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "rooms"
        ],
        "security": [
          {
            "access-token": []
