                }
              }
            }
          }
        },
        "tags": [
          "rooms"
        ],
        "security": [
          {
            "access-token": []
          }
        ]
      },
      "get": {
        "operationId": "RoomsController_list",
        "summary": "List all rooms",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Array of rooms",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RoomDto"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "rooms"
        ],
        "security": [
          {
            "access-token": []
          }
        ]
      }
    },
    "/rooms/{id}": {
      "get": {
        "operationId": "RoomsController_getOne",
        "summary": "Get a single room by id",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Room details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RoomDto"
                }
              }
            }
          }
        },
        "tags": [
          "rooms"
        ],
        "security": [
          {
            "access-token": []
          }
        ]
      }
    },
    "/rooms/{id}/join": {
      "post": {
        "operationId": "RoomsController_join",
        "summary": "Join a room",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Join success flag",
            "content": {
